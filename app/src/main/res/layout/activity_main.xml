<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primaryColor"
    tools:context=".MainActivity">

    <!-- USER DASHBOARD -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutUserDashboard"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Top Header Bar -->
        <View
            android:id="@+id/topBarBg"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="@color/primaryLightColor"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvStatusTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:letterSpacing="0.1"
            android:text="MESH NETWORK"
            android:textColor="@color/primaryTextColor"
            android:textSize="10sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@id/tvConnectionStatus"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/topBarBg"
            app:layout_constraintVertical_chainStyle="packed" />

        <TextView
            android:id="@+id/tvConnectionStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="@string/status_disconnected"
            android:textColor="@color/secondaryTextColor"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/topBarBg"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvStatusTitle" />

        <!-- SOS Pulse Background Wrapper -->
        <FrameLayout
            android:id="@+id/sosPulseWrapper"
            android:layout_width="300dp"
            android:layout_height="300dp"
            android:background="@drawable/bg_sos_pulse"
            app:layout_constraintBottom_toTopOf="@id/toolsRow"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/topBarBg">

            <!-- Core SOS Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSos"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_gravity="center"
                android:elevation="12dp"
                android:letterSpacing="0.1"
                android:stateListAnimator="@null"
                android:text="SOS"
                android:textSize="48sp"
                android:textStyle="bold"
                app:backgroundTint="@color/secondaryColor"
                app:cornerRadius="100dp" />
        </FrameLayout>

        <!-- Tools Row Grid -->
        <LinearLayout
            android:id="@+id/toolsRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="24dp"
            android:orientation="horizontal"
            android:weightSum="2"
            app:layout_constraintBottom_toTopOf="@id/tvRecentTitle"
            app:layout_constraintTop_toBottomOf="@id/sosPulseWrapper">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAiScan"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:text="Hazard Scan"
                android:textColor="@color/white"
                app:backgroundTint="#4527A0"
                app:cornerRadius="12dp"
                app:icon="@android:drawable/ic_menu_camera"
                app:iconTint="@color/white" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFirstAidGuide"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="First Aid"
                android:textColor="@color/white"
                app:backgroundTint="#00695C"
                app:cornerRadius="12dp"
                app:icon="@android:drawable/ic_menu_help"
                app:iconTint="@color/white" />
        </LinearLayout>

        <!-- Logs Section -->
        <TextView
            android:id="@+id/tvRecentTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="8dp"
            android:letterSpacing="0.1"
            android:text="ACTIVITY LEDGER"
            android:textColor="@color/primaryTextColor"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@id/cardLogs"
            app:layout_constraintStart_toStartOf="parent" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardLogs"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/cardBackground"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:layout_constraintBottom_toTopOf="@id/btnRescuerMode"
            app:layout_constraintTop_toBottomOf="@id/tvRecentTitle"
            app:strokeColor="#222222"
            app:strokeWidth="1dp">

            <ScrollView
                android:id="@+id/scrollViewLogs"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvMessageLog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:lineSpacingExtra="4dp"
                    android:text="No recent network activity."
                    android:textColor="#8B949E"
                    android:textSize="14sp" />
            </ScrollView>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRescuerMode"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            android:text="ENTER TEAM HUB \u2192"
            android:textColor="@color/secondaryLightColor"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            app:strokeColor="@color/secondaryColor"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- RESCUER DASHBOARD (Phase 8) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutRescuerDashboard"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:background="@color/primaryColor">

        <!-- Top Header Bar -->
        <View
            android:id="@+id/topBarBgRescuer"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="#2E0A0E"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvRescuerTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:letterSpacing="0.1"
            android:text="RESCUE TEAM HUB"
            android:textColor="@color/secondaryLightColor"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/topBarBgRescuer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/topBarBgRescuer" />

        <TextView
            android:id="@+id/tvRescuerDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="24dp"
            android:text="ACTIVE DISTRESS SIGNALS"
            android:textColor="@color/primaryTextColor"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/topBarBgRescuer" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/cardBackground"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="#9F000A"
            app:strokeWidth="1dp"
            app:layout_constraintBottom_toTopOf="@id/btnExitRescuer"
            app:layout_constraintTop_toBottomOf="@id/tvRescuerDesc">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvRescuerLogs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:lineSpacingExtra="4dp"
                    android:text="> Node ready.\n> Awaiting emergency packets...\n"
                    android:textColor="#DA3633"
                    android:textSize="14sp" />
            </ScrollView>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnExitRescuer"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_margin="16dp"
            android:text="Safely Exit Rescuer View"
            android:textColor="@color/primaryTextColor"
            app:strokeColor="@color/primaryLightColor"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>
