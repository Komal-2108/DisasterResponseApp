<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primaryColor"
    tools:context=".MainActivity">

    <!-- USER DASHBOARD -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutUserDashboard"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <TextView
            android:id="@+id/tvConnectionStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="@string/status_disconnected"
            android:textColor="@color/primaryTextColor"
            android:textSize="16sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSos"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:text="@string/sos_button"
            android:textSize="24sp"
            android:textStyle="bold"
            app:cornerRadius="100dp"
            app:backgroundTint="@color/secondaryColor"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.3" />

        <!-- AI Hazard Scan Button (Phase 7) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAiScan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Run AI Hazard Scan"
            app:icon="@android:drawable/ic_menu_camera"
            app:backgroundTint="#333333"
            app:layout_constraintTop_toBottomOf="@id/btnSos"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvRecentTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginStart="16dp"
            android:text="@string/title_messages"
            android:textColor="@color/secondaryTextColor"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/btnAiScan" />

        <ScrollView
            android:id="@+id/scrollViewLogs"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            app:layout_constraintBottom_toTopOf="@+id/btnRescuerMode"
            app:layout_constraintTop_toBottomOf="@+id/tvRecentTitle">

            <TextView
                android:id="@+id/tvMessageLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/primaryTextColor"
                android:textSize="14sp"
                android:text="No recent network activity." />
        </ScrollView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRescuerMode"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="@string/btn_rescuer_mode"
            android:textColor="@color/secondaryTextColor"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- RESCUER DASHBOARD (Phase 8) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutRescuerDashboard"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvRescuerTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Rescue Team Hub"
            android:textColor="@color/secondaryLightColor"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvRescuerDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Triaging critical distress signals from mesh"
            android:textColor="@color/primaryTextColor"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/tvRescuerTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_margin="16dp"
            app:layout_constraintTop_toBottomOf="@id/tvRescuerDesc"
            app:layout_constraintBottom_toTopOf="@id/btnExitRescuer">
            <TextView
                android:id="@+id/tvRescuerLogs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/primaryTextColor"
                android:textSize="15sp"
                android:lineSpacingExtra="4dp"
                android:text="[AWAITING SIGNALS]\n" />
        </ScrollView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnExitRescuer"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:text="Exit Rescuer View"
            android:textColor="@color/white"
            app:layout_constraintBottom_toBottomOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>
